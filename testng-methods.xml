<?xml version="1.0" encoding="UTF-8"?>

<!-- Method-parallel mode: one browser per test method (fully isolated) -->
<suite name="UI Automation Suite" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.atms.reporting.TestListener"/>
    </listeners>

    <test name="AllTests">
        <classes>
            <class name="com.atms.tests.SauceDemoTest"/>
            <class name="com.atms.tests.AddToCartTest"/>
        </classes>
    </test>

</suite>
